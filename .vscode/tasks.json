{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Check for Marketplace Updates",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/.vscode/update-marketplace.ps1"
            ],
            "problemMatcher": [],
            "group": "none",
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "showReuseMessage": false
            }
        }
    ]
}
